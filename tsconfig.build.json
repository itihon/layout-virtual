{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": "${configDir}",
    "composite": false,
    "declaration": true,
    "declarationDir": "${configDir}/dist",
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "${configDir}/dist",
    "rootDir": "${configDir}/src",
    "tsBuildInfoFile": "${configDir}/dist/.tsbuildinfo"
  }
}
