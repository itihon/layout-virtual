{
  "name": "layout-virtual",
  "version": "0.6.0",
  "description": "Virtualization engine for scrollable responsive lists and grids with dynamic item sizes. Includes the core layout virtualizer and DOM renderer.",
  "keywords": [
    "virtual",
    "virtualized",
    "list",
    "grid",
    "window",
    "scroll",
    "react",
    "vue",
    "angular"
  ],
  "homepage": "https://itihon.github.io/layout-virtual/",
  "bugs": {
    "url": "https://github.com/itihon/layout-virtual/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itihon/layout-virtual.git"
  },
  "license": "MIT",
  "author": "Alexandr Kalabin",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "browser": "dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/types.d.ts",
      "import": "./dist/types/types.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    }
  },
  "scripts": {
    "test": "test",
    "build": "npm run build:bundle && npm run build:types",
    "build:bundle": "vite build",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {}
}
