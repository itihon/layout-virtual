{
  "name": "angular-layout-virtual",
  "version": "0.5.8",
  "description": "Angular virtual scrolling component for responsive lists and grids with dynamic item sizes.",
  "keywords": [
    "virtual",
    "virtualized",
    "list",
    "grid",
    "window",
    "scroll",
    "angular"
  ],
  "homepage": "https://itihon.github.io/layout-virtual/",
  "bugs": {
    "url": "https://github.com/itihon/layout-virtual/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itihon/layout-virtual.git"
  },
  "license": "MIT",
  "author": "Alexandr Kalabin",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "browser": "dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "test",
    "build": "npm run build:bundle && npm run build:types",
    "build:bundle": "vite build",
    "build:types": "ngc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "layout-virtual": "^0.6.8"
  },
  "peerDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/platform-browser": "^21.0.0"
  },
  "devDependencies": {
    "@angular/compiler-cli": "^21.2.14",
    "typescript": "^5.9.2"
  }
}
